# ==============================================================================
# КОНФИГУРАЦИЯ ОКРУЖЕНИЯ ПРОЕКТА
# 
# Инструкция:
# 1. Скопируйте этот файл и назовите его .env (cp .env.example .env)
# 2. Замените значения в угловых скобках <...> на ваши реальные данные
# ==============================================================================

# ------------------------------------------------------------------------------
# [1] ОСНОВНЫЕ НАСТРОЙКИ И МАРШРУТИЗАЦИЯ
# ------------------------------------------------------------------------------

# Режим работы приложения (Production / Development / Staging)
ASPNETCORE_ENVIRONMENT=Development

# Разрешенные источники для CORS (через запятую, без пробелов)
CORS_ORIGINS=http://trampline.localhost,http://trampline.localhost:3000,http://localhost:5173,http://localhost:4173,http://localhost:3000

# Разрешенные хосты для бэкенда (через точку с запятой)
ALLOWED_HOSTS=trampline.localhost;api.trampline.localhost;localhost


# ------------------------------------------------------------------------------
# [2] БАЗЫ ДАННЫХ И КЭШ
# ------------------------------------------------------------------------------
# Пароль для подключения к Redis
REDIS_PASSWORD=redis_s3cret

# Пароль суперпользователя (postgres) для PostgreSQL
POSTGRES_PASSWORD=admin2311


# ------------------------------------------------------------------------------
# [3] АВТОРИЗАЦИЯ И БЕЗОПАСНОСТЬ
# ------------------------------------------------------------------------------
# Настройки JWT (JSON Web Token)
# Ключ должен быть длинным и криптографически стойким (минимум 32 символа)
JWT_KEY=your_very_strong_secret_key_trampline_very_hard_key_trampline
JWT_ISSUER=trampline.localhost/api
JWT_AUDIENCE=trampline.localhost/api

# Базовая авторизация для дашборда Traefik (логин:хеш_пароля)
# Для генерации используйте команду:
# python -c "import bcrypt; print('admin:' + bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode().replace('$','$$'))"
TRAEFIK_DASHBOARD_AUTH=admin:$$2b$$12$$REPLACE_WITH_BCRYPT_HASH


# ------------------------------------------------------------------------------
# [4] ВНЕШНИЕ СЕРВИСЫ И API
# ------------------------------------------------------------------------------
# Интеграция с DaData (https://dadata.ru/)
DADATA_TOKEN=<ваш_токен_dadata>
DADATA_SECRET=<ваш_секретный_ключ_dadata>

# Интеграция с IPInfo (https://ipinfo.io/)
IPINFO_TOKEN=<ваш_токен_ipinfo>


# ------------------------------------------------------------------------------
# [5] ПОЧТА / SMTP (Отправка писем)
# ------------------------------------------------------------------------------
SMTP_HOST=<smtp.example.com>
SMTP_PORT=587
SMTP_USERNAME=<ваш_smtp_логин>
SMTP_PASSWORD=<ваш_smtp_пароль>
SMTP_FROM_EMAIL=noreply@trampline.org


# ------------------------------------------------------------------------------
# [6] WEB PUSH УВЕДОМЛЕНИЯ (VAPID)
# ------------------------------------------------------------------------------
# Ключи для подписи push-уведомлений.
# Сгенерировать новые ключи можно командой: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<ваш_публичный_vapid_ключ>
VAPID_PRIVATE_KEY=<ваш_приватный_vapid_ключ>
VAPID_SUBJECT=mailto:support@trampline.org


# ------------------------------------------------------------------------------
# [7] ФАЙЛОВОЕ ХРАНИЛИЩЕ (S3 / MinIO)
# ------------------------------------------------------------------------------
# Провайдер хранения файлов: local (локальная ФС) или minio (S3 совместимое)
STORAGE_PROVIDER=minio

# Настройки подключения к MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=trampline


# ==============================================================================
# ФРОНТЕНД (Переменные этапа сборки / Build-time)
# Эти переменные будут "вшиты" в клиентский код при сборке
# ==============================================================================

# Базовые настройки фронтенда
PUBLIC_API_URL=/api
PUBLIC_CONTACT_EMAIL=support@trampline.org

# Ссылки на социальные сети
PUBLIC_LINK_VK=https://vk.com/trampline
PUBLIC_LINK_MAX=https://max.ru/trampline
PUBLIC_LINK_DZEN=https://dzen.ru/trampline
PUBLIC_LINK_TELEGRAM=https://t.me/trampline

# Ссылки на ботов
PUBLIC_BOT_VK=https://vk.com/trampline_bot
PUBLIC_BOT_MAX=https://max.ru/trampline_bot
PUBLIC_BOT_TELEGRAM=https://t.me/trampline_bot

# Мобильное приложение
PUBLIC_MOBILE_APP_LINK=https://rutube.ru/video/c6cc4d620b1d4338901770a44b3e82f4/
